# ============================================================
# MindCompass AI — Environment Variables
# Security: no hardcoded API keys anywhere in source code.
# All secrets are loaded exclusively from environment variables.
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ------- Supabase (server + client) -------
# Public URL is safe to expose to the client — it is not a secret.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key is public (RLS enforces access control at DB level).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose client-side. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------- Google Gemini AI -------
# Server-side only — never sent to the browser.
# no hardcoded API keys — loaded exclusively from this env var.
GEMINI_API_KEY=your-gemini-api-key-here

# ------- App Config -------
NEXT_PUBLIC_APP_URL=http://localhost:3000
